# Optional PostgreSQL source of truth. If unset, SQLite queue storage is used for queue APIs.
# WEBPAGE_SORTER_DATABASE_URL=<postgres connection string>
# Legacy name accepted by the extracted plugin:
# SOURCELAB_DATABASE_URL=<postgres connection string>

# Optional Markdown/Git projection repository.
WEBPAGE_SORTER_WIKI_REPO_PATH=/path/to/wiki-or-markdown-repo
WEBPAGE_SORTER_WIKI_BASE_URL=https://example.com
WEBPAGE_SORTER_WIKI_COMMIT=true

# Slack deterministic auto-intake hook.
WEBPAGE_SORTER_PUBLIC_HOST=example.com
SOURCELAB_SLACK_AUTO_INTAKE=true
SOURCELAB_SLACK_AUTO_CHANNELS=C0123456789
SOURCELAB_SLACK_CHANNEL_NAME=sourcelab
SOURCELAB_SLACK_REQUESTED_BY=collector_slack_auto
SOURCELAB_SLACK_CONFIDENCE_THRESHOLD=0.8

# Low-cost analysis provider is resolved through Hermes auxiliary model config.

# Optional social-source adapters. Keep real values out of git and load them from
# a chmod 600 local env file or the process supervisor.
# X/Twitter uses twitter-cli cookies:
# TWITTER_AUTH_TOKEN=<x auth_token cookie>
# TWITTER_CT0=<x ct0 cookie>
# Reddit uses rdt-cli's credential file, normally at:
# ~/.config/rdt-cli/credential.json
